---
import '../styles/global.css';
import { withBase } from '../lib/paths';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const siteName = 'AI Humor Media';
const description =
  Astro.props.description ?? '真剣にバカなことを検証する、日本語ユーモア記事メディア。';
const title = Astro.props.title ? `${Astro.props.title} | ${siteName}` : siteName;
const image = Astro.props.image ?? '/images/aizuchi-performance-test/eyecatch.png';
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const imageUrl = new URL(withBase(image), siteUrl).toString();
const rssUrl = new URL(withBase('/rss.xml'), siteUrl).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href={rssUrl} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="brand" href={withBase('/')} aria-label="AI Humor Media home">
            <span class="brand__mark" aria-hidden="true"></span>
            <span>{siteName}</span>
          </a>
          <nav class="nav" aria-label="Primary">
            <a href={withBase('/articles/aizuchi-performance-test/')}>最新記事</a>
            <a href={withBase('/tags/')}>タグ</a>
            <a href={withBase('/about/')}>運用</a>
            <a href={withBase('/rss.xml')}>RSS</a>
          </nav>
        </div>
      </header>
      <main class="main">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="site-footer__inner">
          <span>AI Humor Media</span>
          <span>真面目な顔で、役に立たない検証をします。</span>
        </div>
      </footer>
    </div>
  </body>
</html>
