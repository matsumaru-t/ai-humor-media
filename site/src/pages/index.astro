---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const featured = articles[0];
---

<BaseLayout>
  <section class="hero">
    <div>
      <span class="section-kicker">YOKEI LAB</span>
      <h1>どうでもいいことを、全力でためす。</h1>
      <p>
        よけいラボは、ふつうなら三秒で忘れる疑問を、ちゃんと集まってやってみる編集部です。
        小さなことを大げさにして、最後に少しだけ役に立たない答えを出します。
      </p>
      {featured && (
        <ul class="tag-list" aria-label="Featured tags">
          {featured.data.tags.slice(0, 5).map((tag) => (
            <li><a class="tag" href={withBase(`/tags/${encodeURIComponent(tag)}/`)}>{tag}</a></li>
          ))}
        </ul>
      )}
    </div>
    <a class="hero__media" href={withBase('/about/')} aria-label="よけいラボ編集部">
      <img src={withBase('/images/site/editorial-desk.png')} alt="机を囲んで日用品を調べている編集部" />
    </a>
  </section>

  <section aria-labelledby="latest">
    <span class="section-kicker">REPORTS</span>
    <h2 id="latest">最近やってみたこと</h2>
    <div class="article-grid">
      {articles.map((article) => (
        <article class="article-card">
          <a href={withBase(`/articles/${article.data.slug}/`)}>
            {article.data.eyecatch && (
              <img src={withBase(article.data.eyecatch)} alt={article.data.eyecatchAlt ?? ''} />
            )}
            <div class="article-card__body">
              <div class="article-card__meta">
                <time datetime={article.data.publishDate.toISOString()}>
                  {article.data.publishDate.toLocaleDateString('ja-JP')}
                </time>
                {' / '}
                {article.data.author}
              </div>
              <h2>{article.data.title}</h2>
              <p>{article.data.description}</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
